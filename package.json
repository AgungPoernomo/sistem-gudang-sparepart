{
  "name": "pergudangan-sparepart-satoria",
  "version": "1.0.0",
  "description": "Sistem Pergudangan Sparepart",
  "main": "index.js",
  "scripts": {
    "build:css": "npx tailwindcss -i ./src/app/globals.css -o ./public/style.css",
    "watch:css": "npx tailwindcss -i ./src/app/globals.css -o ./public/style.css --watch",
    "serve": "live-server --entry-file=./src/app/login/index.html",
    "dev": "concurrently \"npm run watch:css\" \"npm run serve\"",
    "update-map": "node generate-map.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "autoprefixer": "^10.0.0",
    "concurrently": "^8.0.0",
    "live-server": "^1.2.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.4.0"
  }
}